#!/usr/bin/env bash
set -euo pipefail

NIX_SECRETS_DIR="$HOME/github/mgrbyte/nix-secrets"
NIX_CONFIG_DIR="$HOME/github/mgrbyte/nix-config"
AGE_RECIPIENT="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAILmPyaobKItjwejTB0TyS10e4HM/HyvbBRo7Mt9CKysc"

usage() {
    echo "Usage: add-secret <secret-name> <source-file>"
    echo "  e.g. add-secret work.netrc ~/Downloads/new.netrc"
    echo ""
    echo "Encrypts <source-file> into nix-secrets as <secret-name>.age,"
    echo "commits and pushes nix-secrets, then bumps the nix-config flake lock."
    echo "Use update-secret to change an existing secret."
    exit 1
}

if [[ $# -ne 2 ]]; then
    usage
fi

secret_name="$1"
source_file="$2"
age_file="$NIX_SECRETS_DIR/${secret_name}.age"

if [[ ! -f "$source_file" ]]; then
    echo "Error: source file $source_file does not exist"
    usage
fi

if [[ -e "$age_file" ]]; then
    echo "Error: $age_file already exists. Use update-secret to change it."
    exit 1
fi

rage -r "$AGE_RECIPIENT" -o "$age_file" "$source_file"
echo "Encrypted $source_file -> ${secret_name}.age"

git -C "$NIX_SECRETS_DIR" add "${secret_name}.age"
git -C "$NIX_SECRETS_DIR" commit -m "Add ${secret_name}"
git -C "$NIX_SECRETS_DIR" push
echo "Committed and pushed nix-secrets"

nix flake update nix-secrets --flake "$NIX_CONFIG_DIR" --commit-lock-file
echo "Updated and committed nix-config flake lock"

echo ""
echo "Secret added. Next: register it in home/age.nix secretFiles, e.g."
echo ""
echo "    \"${secret_name}\" = {"
echo "      source = \"\${nix-secrets}/${secret_name}.age\";"
echo "      symlinks = [ \"\${homeDir}/path/to/target\" ];"
echo "    };"
echo ""
echo "Then run hm-switch to deploy."
