{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#bb9af7",
          "style": "plain",
          "template": "{{ .UserName }}{{ if .SSHSession }}@{{ .HostName }}{{ end }} ",
          "type": "session"
        },
        {
          "foreground": "#c0caf5",
          "style": "plain",
          "template": "in ",
          "type": "text"
        },
        {
          "foreground": "#9ece6a",
          "options": {
            "style": "full"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#7dcfff",
          "options": {
            "branch_ahead_icon": "",
            "branch_behind_icon": "",
            "branch_gone_icon": "",
            "branch_icon": "",
            "branch_identical_icon": "",
            "cherry_pick_icon": "",
            "commit_icon": "",
            "fetch_status": true,
            "merge_icon": "",
            "rebase_icon": "",
            "revert_icon": "",
            "tag_icon": ""
          },
          "style": "plain",
          "template": "<#c0caf5>on</> {{ .HEAD }}{{ if .Staging.Changed }}<#9ece6a> \u25cf {{ .Staging.String }}</>{{ end }}{{ if .Working.Changed }}<#ff9e64> \u25cf {{ .Working.String }}</>{{ end }} ",
          "type": "git"
        },
        {
          "foreground": "#ff9e64",
          "style": "plain",
          "template": "λ ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
